<%- include('../_header', { title: 'Admin' }) %>
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
  <h1 class="page-title" style="margin:0">Admin Dashboard</h1>
  <div style="display:flex;gap:8px;align-items:center">
    <a href="/admin/test" class="btn btn-secondary btn-sm">🧪 Test</a>
    <a href="/admin/logout" class="btn btn-secondary btn-sm">Logout</a>
  </div>
</div>

<div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px">
  <a href="/admin/print" target="_blank" class="btn btn-sm btn-secondary">🖨️ Print Standings</a>
  <a href="/admin/setup" class="btn btn-sm">⚙️ Edit Teams</a>
  <% if (teams.length > 0 && groupMatches.length === 0) { %>
  <form method="POST" action="/admin/generate-schedule" style="display:inline">
    <button type="submit" class="btn btn-sm">📅 Generate Schedule</button>
  </form>
  <% } %>
  <% if (groupMatches.length > 0 && allGroupDone && bracketMatches.length === 0) { %>
  <form method="POST" action="/admin/advance-bracket" style="display:inline">
    <button type="submit" class="btn btn-sm" style="background:var(--gold)">🏆 Seed Bracket</button>
  </form>
  <% } %>
</div>

<% if (teams.length === 0) { %>
<div class="alert alert-info">No teams yet. <a href="/admin/setup">Add teams</a> to get started.</div>
<% } %>

<% if (groupMatches.length > 0) { %>
<details <%= allGroupDone ? '' : 'open' %> style="margin-bottom:24px">
  <summary class="section-title" style="cursor:pointer;list-style:none;display:flex;align-items:center;gap:6px">
    Standings <span style="font-size:0.75rem;color:var(--muted)"><%= allGroupDone ? '(group phase complete)' : '' %></span>
  </summary>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:10px">
    <% ['A', 'B'].forEach(g => { %>
    <div>
      <p style="font-weight:600;margin-bottom:8px;color:var(--muted)">Group <%= g %></p>
      <table class="standings-table">
        <thead><tr><th>Team</th><th>W</th><th>L</th></tr></thead>
        <tbody>
          <% (standings[g] || []).forEach((s, i) => { %>
          <tr class="<%= i < 2 ? 'advance' : (i < 4 ? 'silver-zone' : '') %>">
            <td style="display:flex;align-items:center;gap:8px">
              <% if (s.team.icon_path && s.team.icon_path.startsWith('/')) { %><img src="<%= s.team.icon_path %>" alt="" class="team-icon"><% } else if (s.team.icon_path) { %><span class="team-icon-placeholder"><%= s.team.icon_path %></span><% } else { %><span class="team-icon-placeholder"><%= s.team.name.charAt(0).toUpperCase() %></span><% } %>
              <%= s.team.name %>
            </td>
            <td><%= s.wins %></td>
            <td><%= s.losses %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% }); %>
  </div>
</details>
<% } %>

<% if (groupMatches.length > 0) { %>
<details <%= allGroupDone ? '' : 'open' %> style="margin-bottom:24px">
  <summary class="section-title" style="cursor:pointer;list-style:none;display:flex;align-items:center;gap:6px">
    Group Stage <span style="font-size:0.75rem;color:var(--muted)"><%= allGroupDone ? '(complete)' : '' %></span>
  </summary>
  <div style="margin-top:10px">
    <% for (const m of groupMatches) { %>
    <%- include('../_match_row', { m }) %>
    <% } %>
  </div>
</details>
<% } %>

<% if (bracketMatches.length > 0) { %>
<p class="section-title">Bracket</p>
<% for (const m of bracketMatches) { %>
<%- include('../_match_row', { m }) %>
<% } %>
<% } %>

<%- include('../_footer') %>
